{
  "name": "steam-deals-tool",
  "version": "1.0.0",
  "description": "Steam 优惠折扣与新游戏浏览工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.steam-deals-tool",
    "productName": "Steam优惠工具",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
